<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_Man_X" Id="{a582f58c-ea54-4df0-a7a5-b6e3e4d79fbe}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_Man_X
VAR_INPUT
    bEnable         : BOOL;  // Reglerfreigabe generelle
    bExecute        : BOOL;  // Startet die absolute Positionierfahrt
    bHalt           : BOOL;  // Sanftes Abbremsen (für normalen Ablauf)
    
    // Sensoren (True = betätigt / belegt)
    bEndSchalterMin : BOOL;  // Linker Endschalter (Gleichzeitig unser Referenzschalter!)
    bEndSchalterMax : BOOL;  // Rechter Endschalter
    bSens4          : BOOL;  // Sensor Bandende
    
    // Fahrparameter
    fPosition       : LREAL; // Zielposition für die absolute Fahrt
    fVelocity       : LREAL; // Zielgeschwindigkeit
    pHome           : LREAL; // Positionswert, der bei Referenzierung gesetzt wird (z.B. 0.0)
END_VAR

VAR_OUTPUT
    eState          : E_State; // Zustandsausgabe für die Main
    fActPos         : LREAL;   // Aktuelle Position für die Anzeige (X)
    
    // Greifer und Freigabe
    bGreifer        : BOOL;    // TRUE = Greifer zu, FALSE = Greifer auf
    bBandFrei       : BOOL;    // TRUE = Flasche weg, nächstes Modul darf starten!
END_VAR

VAR_IN_OUT
    ax              : AXIS_REF; // Verknüpfung zur NC-Achse X
    axY             : AXIS_REF; // Verknüpfung zur virtuellen Achse Y
    axZ             : AXIS_REF; // Verknüpfung zur virtuellen Achse Z
END_VAR

VAR
    // Interne State-Machine Variablen
    nState          : INT;
    bStop           : BOOL;     // Lokale Kopie vom globalen Not-Halt (aus ifc_hw.bStop)
    fbTimer         : TON;      // Timer für das Greifen/Loslassen

    // --- Motion Control Bausteine (X-Achse) ---
    mcPower         : MC_Power;
    mcReset         : MC_Reset;
    mcVelocity      : MC_MoveVelocity; 
    mcMoveAbs       : MC_MoveAbsolute; 
    mcHalt          : MC_Halt;         
    mcStop          : MC_Stop;         
    mcSetPos        : MC_SetPosition;  

    // --- Motion Control Bausteine (Y-Achse virtuell) ---
    mcPowerY        : MC_Power;
    mcMoveAbsY      : MC_MoveAbsolute;

    // --- Motion Control Bausteine (Z-Achse virtuell) ---
    mcPowerZ        : MC_Power;
    mcMoveAbsZ      : MC_MoveAbsolute;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[

// Timer für den Greifer aufrufen
fbTimer();

// Fehlerüberwachung (Sammelt Errors von ALLEN genutzten Achsen und MC-Bausteinen)
IF (ax.Status.Error OR axY.Status.Error OR axZ.Status.Error OR mcMoveAbs.Error OR mcVelocity.Error OR mcSetPos.Error) AND nState <> 100 THEN
    nState := 99;
END_IF

bStop := ifc_Hw.bStop; // Globale Stop-Variable einlesen

// Stopen über Not-Aus (bStop) oder bEnable weg
IF (bStop OR NOT bEnable) AND nState >= 3 AND nState < 80 THEN
    nState := 80; 
END_IF

// ==========================================
// STATE MACHINE
// ==========================================
CASE nState OF
    0: // Off
        eState := E_State.Off;
        bBandFrei := FALSE;
        bGreifer  := FALSE;
        
        mcPower.Enable := FALSE;
        mcVelocity.Execute := FALSE;
        mcMoveAbs.Execute := FALSE;
        mcHalt.Execute := FALSE;
        mcStop.Execute := FALSE;
        mcReset.Execute := FALSE;
        mcSetPos.Execute := FALSE;
        
        IF bEnable THEN
            nState := 1;
        END_IF
        
    1: // Init (Power On)
        eState := E_State.Init;
        mcPower.Enable := TRUE; // Startet auch Y und Z unten!
        
        IF mcPower.Status THEN 
            nState := 10; // Gehe zur Referenzfahrt für X
        END_IF
        IF NOT bEnable THEN nState := 0; END_IF 
        
    // ==========================================
    // REFERENZFAHRT (Nur X-Achse benötigt das wirklich)
    // ==========================================
    10: // Homing Start (Fahrt nach links)
        eState := E_State.Init; 
        mcVelocity.Velocity := 15.0; 
        mcVelocity.Direction := MC_Negative_Direction; // Nach links zum Min-Schalter
        mcVelocity.Execute := TRUE;
        
        IF NOT bEndSchalterMin THEN
            mcVelocity.Execute := FALSE;
            nState := 11;
        END_IF

    11: // Homing Stop (Am Schalter anhalten)
        mcHalt.Execute := TRUE;
        IF mcHalt.Done THEN
            mcHalt.Execute := FALSE;
            nState := 12;
        END_IF

    12: // Position auf pHome (0.0) nullen
        mcSetPos.Position := pHome;
        mcSetPos.Execute := TRUE;
        
        IF mcSetPos.Done THEN
            mcSetPos.Execute := FALSE;
            nState := 2; // Referenzfahrt fertig -> Ready!
        END_IF
        
    // ==========================================
    // NORMALBETRIEB (Warten auf Flasche)
    // ==========================================
    2: // Ready 
        eState := E_State.Ready;
        mcVelocity.Execute := FALSE;
        mcHalt.Execute := FALSE;
        mcStop.Execute := FALSE;
        bBandFrei := FALSE; // Blockiert das Band, solange wir warten
        
        // Der Manipulator startet jetzt vollautomatisch, sobald die Flasche ankommt!
        IF bSens4 THEN
            nState := 20;
        END_IF
        IF NOT bEnable THEN nState := 0; END_IF
        
    // ==========================================
    // ZYKLUS: PICK & PLACE (Die Choreografie)
    // ==========================================
    20: // 1. Z-Achse nach unten fahren (zur Flasche)
        eState := E_State.Production;
        mcMoveAbsZ.Position := 100.0; // TIEFE ANPASSEN WENN NÖTIG!
        mcMoveAbsZ.Velocity := 150.0;
        mcMoveAbsZ.Execute  := TRUE;
        
        IF mcMoveAbsZ.Done THEN
            mcMoveAbsZ.Execute := FALSE;
            nState := 21;
        END_IF

    21: // 2. Flasche greifen
        bGreifer := TRUE; 
        fbTimer(IN := TRUE, PT := T#0.5S); // Warten bis Greifer mechanisch zu ist
        
        IF fbTimer.Q THEN
            fbTimer(IN := FALSE);
            nState := 22;
        END_IF

    22: // 3. Z-Achse wieder hochfahren
        mcMoveAbsZ.Position := 0.0; // Zurück auf Null (Oben)
        mcMoveAbsZ.Execute  := TRUE;
        
        IF mcMoveAbsZ.Done THEN
            mcMoveAbsZ.Execute := FALSE;
            
            // WICHTIG: Flasche ist in der Luft! Das Band darf weiterarbeiten!
            bBandFrei := TRUE; 
            nState := 23;
        END_IF

    23: // 4. X nach rechts UND Y nach hinten fahren (Gleichzeitig!)
        // X fährt auf Endschalter Max
        mcVelocity.Velocity  := 150.0;
        mcVelocity.Direction := MC_Positive_Direction;
        mcVelocity.Execute   := TRUE;
        
        // Y fährt auf Position
        mcMoveAbsY.Position := 200.0; // Y-TIEFE INS LAGER ANPASSEN!
        mcMoveAbsY.Velocity := 150.0;
        mcMoveAbsY.Execute  := TRUE;
        
        // Warten, bis BEIDE angekommen sind (X am Sensor, Y am Ziel)
        IF NOT bEndSchalterMax AND mcMoveAbsY.Done THEN 
            mcVelocity.Execute := FALSE;
            mcMoveAbsY.Execute := FALSE;
            mcHalt.Execute     := TRUE; // X-Achse abbremsen
            nState := 24;
        END_IF

    24: // 5. Warten bis X-Achse steht
        IF mcHalt.Done THEN
            mcHalt.Execute := FALSE;
            nState := 25;
        END_IF

    25: // 6. Z-Achse nach unten (ins Lager)
        mcMoveAbsZ.Position := 100.0; 
        mcMoveAbsZ.Execute  := TRUE;
        
        IF mcMoveAbsZ.Done THEN
            mcMoveAbsZ.Execute := FALSE;
            nState := 26;
        END_IF

    26: // 7. Flasche loslassen
        bGreifer := FALSE;
        fbTimer(IN := TRUE, PT := T#0.5S); // Warten bis Greifer offen ist
        
        IF fbTimer.Q THEN
            fbTimer(IN := FALSE);
            nState := 27;
        END_IF

    27: // 8. Z-Achse wieder hoch (ohne Flasche)
        mcMoveAbsZ.Position := 0.0; 
        mcMoveAbsZ.Execute  := TRUE;
        
        IF mcMoveAbsZ.Done THEN
            mcMoveAbsZ.Execute := FALSE;
            nState := 28;
        END_IF

    28: // 9. X und Y zurück zur Grundstellung (Gleichzeitig!)
        mcVelocity.Direction := MC_Negative_Direction; // X nach links
        mcVelocity.Execute   := TRUE;
        
        mcMoveAbsY.Position := 0.0; // Y wieder nach vorne
        mcMoveAbsY.Execute  := TRUE;
        
        IF NOT bEndSchalterMin AND mcMoveAbsY.Done THEN 
            mcVelocity.Execute := FALSE;
            mcMoveAbsY.Execute := FALSE;
            mcHalt.Execute     := TRUE;
            nState := 29;
        END_IF

    29: // 10. Warten bis X steht -> Fertig!
        IF mcHalt.Done THEN
            mcHalt.Execute := FALSE;
            bBandFrei := FALSE; // Reset für den nächsten Durchlauf
            nState := 2; // Zurück auf Lauerstellung!
        END_IF
        
    // ==========================================
    // NOT-HALT / STOP
    // ==========================================
    80: // Stop Achse (Harter Stopp)
        mcMoveAbs.Execute := FALSE;
        mcVelocity.Execute := FALSE;
        mcHalt.Execute := FALSE;
        mcMoveAbsY.Execute := FALSE;
        mcMoveAbsZ.Execute := FALSE;
        mcStop.Execute := TRUE;
        
        IF mcStop.Done AND NOT bStop THEN
            nState := 81;
        END_IF
        
    81: // Stop lösen
        mcStop.Execute := FALSE; 
        nState := 1; // Sicherer Neustart inkl. Homing
    
    // ==========================================
    // ERROR HANDLING
    // ==========================================
    99: // Error State
        eState := E_State.Error;
        mcPower.Enable := FALSE;
        mcVelocity.Execute := FALSE;
        mcMoveAbs.Execute := FALSE;
        mcMoveAbsY.Execute := FALSE;
        mcMoveAbsZ.Execute := FALSE;
        mcHalt.Execute := FALSE;
        mcStop.Execute := FALSE;
        
        IF bEnable THEN 
            nState := 100;
        END_IF
        
    100: // Resolve / Reset
        mcReset.Execute := TRUE;
        
        IF mcReset.Done THEN
            mcReset.Execute := FALSE;
            nState := 1; // Neustart
        ELSIF mcReset.Error THEN
            mcReset.Execute := FALSE;
            nState := 99; // Reset fehlgeschlagen
        END_IF
        
END_CASE

// ==========================================
// BAUSTEINE AUFRUFEN (Am Ende des Zyklus)
// ==========================================

// --- X-ACHSE ---
mcPower(
    Axis            := ax, 
    Enable          := mcPower.Enable, 
    Enable_Positive := mcPower.Enable AND bEndSchalterMax, 
    Enable_Negative := mcPower.Enable AND bEndSchalterMin, 
    Override        := 100.0
);
mcReset(Axis := ax, Execute := mcReset.Execute);
mcVelocity(Axis := ax, Execute := mcVelocity.Execute, Velocity := mcVelocity.Velocity, Direction := mcVelocity.Direction);
mcMoveAbs(Axis := ax, Execute := mcMoveAbs.Execute, Position := mcMoveAbs.Position, Velocity := mcMoveAbs.Velocity);
mcHalt(Axis := ax, Execute := mcHalt.Execute);
mcStop(Axis := ax, Execute := mcStop.Execute);
mcSetPos(Axis := ax, Execute := mcSetPos.Execute, Position := mcSetPos.Position);
fActPos := ax.NcToPlc.ActPos;

// --- Y-ACHSE (Virtuell) ---
mcPowerY(
    Axis            := axY, 
    Enable          := mcPower.Enable, 
    Enable_Positive := mcPower.Enable, // Keine Sensoren -> Immer TRUE solange Enable
    Enable_Negative := mcPower.Enable,
    Override        := 100.0
);
mcMoveAbsY(Axis := axY, Execute := mcMoveAbsY.Execute, Position := mcMoveAbsY.Position, Velocity := mcMoveAbsY.Velocity);

// --- Z-ACHSE (Virtuell) ---
mcPowerZ(
    Axis            := axZ, 
    Enable          := mcPower.Enable, 
    Enable_Positive := mcPower.Enable,
    Enable_Negative := mcPower.Enable,
    Override        := 100.0
);
mcMoveAbsZ(Axis := axZ, Execute := mcMoveAbsZ.Execute, Position := mcMoveAbsZ.Position, Velocity := mcMoveAbsZ.Velocity);]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>